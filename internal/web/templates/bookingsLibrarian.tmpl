<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Бронирования</title>
    <style>
        .booking {
            border: 1px solid #ccc;
            margin: 10px 0;
            padding: 10px;
        }
        button {
            margin-top: 10px;
        }
        input, button {
            padding: 5px;
        }
    </style>
</head>
<body>
    <h1>Бронирования читателей</h1>
    <div>
        <input type="text" id="libraryCard" placeholder="Введите читательский билет (email)">
        <button id="loadBtn">Поиск</button>
    </div>
    <div id="bookings"></div>

    <script>
        const libraryCardInput = document.getElementById('libraryCard');
        const loadBtn = document.getElementById('loadBtn');
        const container = document.getElementById('bookings');

        loadBtn.onclick = async () => {
            const libraryCard = libraryCardInput.value.trim();
            if (!libraryCard) return alert('Введите читательский билет');

            container.innerHTML = 'Загрузка...';
            try {
            
                const res = await fetch('/getCurrentBookings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ readerLibraryCard: libraryCard })
                });
                if (!res.ok) throw new Error(await res.text());
                const bookings = await res.json();

                if (!bookings.length) {
                    container.innerHTML = '<p>Активных бронирований нет</p>';
                    return;
                }

                let html = '';
                for (const b of bookings) {
                    const authors = (b.authors || []).join(', ');
                    const isbns = (b.isbns || []).join(', ');
                    const other = (b.otherindexes || []).join(', ');
                    const bbks = (b.bbks || []).join(' + ');

                    html += `
                        <div class="booking" data-inventory-number="${b.inventorynumber}">
                            <p><strong>Инв. номер:</strong> ${escapeHtml(b.inventorynumber)}</p>
                            <p><strong>Название:</strong> ${escapeHtml(b.title)} (${escapeHtml(b.publicationyear)})</p>
                            <p><strong>Авторы:</strong> ${escapeHtml(authors)}</p>
                            <p><strong>ISBN:</strong> ${escapeHtml(isbns)}</p>
                            <p><strong>ББК:</strong> ${escapeHtml(bbks)}</p>
                            <p><strong>Другие индексы:</strong> ${escapeHtml(other)}</p>
                            <p><strong>Здание:</strong> ${escapeHtml(b.buildingaddress || '')}</p>
                            <button class="issue-btn" data-inventory-number="${b.inventorynumber}">Выдать</button>
                        </div>
                    `;
                }
                container.innerHTML = html;

                // Обработчики для кнопок "Выдать"
                document.querySelectorAll('.issue-btn').forEach(btn => {
                    btn.onclick = async () => {
                        const inventoryNumber = btn.dataset.inventoryNumber;
                        const libraryCard = libraryCardInput.value.trim();
                        if (!libraryCard) {
                            alert('Читательский билет не задан');
                            return;
                        }
                        btn.disabled = true;
                        btn.textContent = '...';
                        try {
                            const resp = await fetch('/makeLoan', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ readerlibrarycard: libraryCard, inventorynumber: inventoryNumber })
                            });
                            if (!resp.ok) throw new Error(await resp.text());
                            alert('Книга выдана!');
                            btn.closest('.booking').remove();
                            if (container.children.length === 0) container.innerHTML = '<p>Активных бронирований нет</p>';
                        } catch (err) {
                            alert('Ошибка: ' + err.message);
                        } finally {
                            btn.disabled = false;
                            btn.textContent = 'Выдать';
                        }
                    };
                });
            } catch (err) {
                container.innerHTML = `<p style="color:red">Ошибка: ${escapeHtml(err.message)}</p>`;
            }
        };

        function escapeHtml(str) {
            if (str == null) return '';
            str = String(str);
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
    </script>
</body>
</html>